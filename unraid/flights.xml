<?xml version="1.0"?>
<Container version="2">
  <Name>flights</Name>
  <Repository>ghcr.io/ronschaeffer/flights:latest</Repository>
  <Registry>https://github.com/ronschaeffer/flights/pkgs/container/flights</Registry>
  <Network>bridge</Network>
  <Privileged>false</Privileged>
  <Support>https://github.com/ronschaeffer/flights/issues</Support>
  <Project>https://github.com/ronschaeffer/flights</Project>
  <Overview>ADS-B flight data enrichment with MQTT publishing and Home Assistant integration. Fetches aircraft data from a local ADS-B receiver, enriches with airline/airport/route information, and publishes to MQTT. Includes HTTP API with airline logos and country flags.</Overview>
  <Category>HomeAutomation: Tools:</Category>
  <WebUI>http://[IP]:[PORT:47475]/</WebUI>
  <Icon>https://raw.githubusercontent.com/ronschaeffer/flights/main/icon.png</Icon>
  <ExtraParams>--add-host=host.docker.internal:host-gateway</ExtraParams>
  <DonateImg/>
  <DonateLink/>
  <Requires/>

  <!-- Web Server -->
  <Config Name="Web Server Port" Target="47475" Default="47475" Mode="tcp" Description="Web server port for API and UI" Type="Port" Display="always" Required="true" Mask="false">47475</Config>
  <Config Name="External URL" Target="WEB_SERVER_EXTERNAL_URL" Default="" Mode="" Description="External URL for HA integration (e.g. http://YOUR_HOST_IP:47475)" Type="Variable" Display="always" Required="false" Mask="false"/>

  <!-- ADS-B Receiver -->
  <Config Name="Dump URL" Target="DUMP_URL" Default="" Mode="" Description="ADS-B receiver URL (e.g. http://192.168.1.100:30053/ajax/aircraft)" Type="Variable" Display="always" Required="true" Mask="false"/>
  <Config Name="Check Interval" Target="CHECK_INTERVAL" Default="15" Mode="" Description="Seconds between receiver checks" Type="Variable" Display="advanced" Required="false" Mask="false">15</Config>

  <!-- MQTT Configuration -->
  <Config Name="MQTT Broker URL" Target="MQTT_BROKER_URL" Default="" Mode="" Description="MQTT broker hostname or IP address" Type="Variable" Display="always" Required="true" Mask="false"/>
  <Config Name="MQTT Broker Port" Target="MQTT_BROKER_PORT" Default="1883" Mode="" Description="MQTT broker port" Type="Variable" Display="always" Required="true" Mask="false">1883</Config>
  <Config Name="MQTT Security" Target="MQTT_SECURITY" Default="none" Mode="" Description="MQTT security mode: none or username" Type="Variable" Display="always" Required="false" Mask="false">none</Config>
  <Config Name="MQTT Username" Target="MQTT_USERNAME" Default="" Mode="" Description="MQTT username (if security is 'username')" Type="Variable" Display="always" Required="false" Mask="false"/>
  <Config Name="MQTT Password" Target="MQTT_PASSWORD" Default="" Mode="" Description="MQTT password" Type="Variable" Display="always" Required="false" Mask="true"/>
  <Config Name="MQTT Use TLS" Target="MQTT_USE_TLS" Default="false" Mode="" Description="Enable TLS for MQTT connection (true/false)" Type="Variable" Display="always" Required="false" Mask="false">false</Config>
  <Config Name="TLS Verify" Target="TLS_VERIFY" Default="true" Mode="" Description="Verify TLS certificates (set false for self-signed)" Type="Variable" Display="always" Required="false" Mask="false">true</Config>

  <!-- Home Assistant -->
  <Config Name="Home Assistant Enabled" Target="HOME_ASSISTANT_ENABLED" Default="true" Mode="" Description="Enable Home Assistant MQTT discovery" Type="Variable" Display="always" Required="false" Mask="false">true</Config>

  <!-- Location -->
  <Config Name="Latitude" Target="USER_LAT" Default="" Mode="" Description="Observer latitude" Type="Variable" Display="always" Required="false" Mask="false"/>
  <Config Name="Longitude" Target="USER_LON" Default="" Mode="" Description="Observer longitude" Type="Variable" Display="always" Required="false" Mask="false"/>
  <Config Name="Distance Unit" Target="DISTANCE_UNIT" Default="mi" Mode="" Description="Distance unit: mi or km" Type="Variable" Display="advanced" Required="false" Mask="false">mi</Config>
  <Config Name="Altitude Unit" Target="ALTITUDE_UNIT" Default="ft" Mode="" Description="Altitude unit: ft or m" Type="Variable" Display="advanced" Required="false" Mask="false">ft</Config>

  <!-- Logging -->
  <Config Name="Log Level" Target="LOG_LEVEL" Default="INFO" Mode="" Description="Log level: DEBUG, INFO, WARNING, ERROR" Type="Variable" Display="advanced" Required="false" Mask="false">INFO</Config>

  <!-- Volumes -->
  <Config Name="Config Directory" Target="/app/config" Default="/mnt/user/appdata/flights/config" Mode="rw" Description="Configuration files (config.yaml)" Type="Path" Display="always" Required="true" Mask="false">/mnt/user/appdata/flights/config</Config>
  <Config Name="Data Directory" Target="/app/data" Default="/mnt/user/appdata/flights/data" Mode="rw" Description="Data storage (airlines, aircraft databases)" Type="Path" Display="always" Required="true" Mask="false">/mnt/user/appdata/flights/data</Config>
  <Config Name="Storage Directory" Target="/app/storage" Default="/mnt/user/appdata/flights/storage" Mode="rw" Description="Persistent storage (flight counts)" Type="Path" Display="always" Required="false" Mask="false">/mnt/user/appdata/flights/storage</Config>
  <Config Name="Output Directory" Target="/app/output" Default="/mnt/user/appdata/flights/output" Mode="rw" Description="Output files (JSON data, missing codes log)" Type="Path" Display="always" Required="false" Mask="false">/mnt/user/appdata/flights/output</Config>
</Container>
