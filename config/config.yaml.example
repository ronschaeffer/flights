# Flights configuration
# Copy to config.yaml and fill in your values.
# All settings can also be overridden via environment variables
# (e.g. MQTT_BROKER_URL, WEB_SERVER_PORT, DUMP_URL).

app:
  name: "Flights"
  unique_id_prefix: "flights"
  manufacturer: "ronschaeffer"
  model: "Flights"

mqtt:
  broker_url: ""              # MQTT broker hostname or IP
  broker_port: 1883
  client_id: "flights_client"
  security: "none"            # none | username
  auth:
    username: ""
    password: ""
  tls:
    verify: true
  topics:
    visible: "flights/visible"
    closest: "flights/closest"
    availability: "flights/availability"

home_assistant:
  enabled: true
  discovery_prefix: "homeassistant"

web_server:
  enabled: true
  host: "0.0.0.0"
  port: 47475
  external_url: ""            # e.g. http://YOUR_HOST_IP:47475 (required for Docker)
  image_format: "svg"         # svg or png

receiver:
  dump_url: ""                # ADS-B receiver URL, e.g. http://192.168.1.100:30053/ajax/aircraft
  check_interval: 15          # Seconds between checks

location:
  lat: 0.0
  lon: 0.0
  radius: 10                  # Distance from user position
  distance_unit: "mi"         # mi or km
  altitude_unit: "ft"         # ft or m
  use_config_location: false

zone:
  lat_south: 0.0
  lat_north: 0.0
  lon_west: 0.0
  lon_east: 0.0
  max_alt: 3000
  min_alt: 0

logging:
  level: "INFO"               # DEBUG, INFO, WARNING, ERROR, CRITICAL
